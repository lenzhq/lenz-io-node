{
  "name": "lenz-io",
  "version": "2.4.0",
  "description": "Official Node SDK for the Lenz Fact Checking API for AI Product Teams",
  "license": "MIT",
  "author": "Lenz <support@lenz.io>",
  "homepage": "https://lenz.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lenzhq/lenz-io-node.git"
  },
  "bugs": {
    "url": "https://github.com/lenzhq/lenz-io-node/issues"
  },
  "keywords": [
    "lenz",
    "fact-check",
    "llm",
    "hallucination",
    "verification",
    "api",
    "sdk",
    "ai"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.browser.js"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "sync-version": "node scripts/sync-version.mjs",
    "prebuild": "npm run --silent sync-version",
    "build": "tsup",
    "pretest": "npm run --silent sync-version",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run test/smoke.test.ts",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "pretype": "npm run --silent sync-version",
    "type": "tsc --noEmit",
    "regen": "if [ -z \"$LENZ_REPO\" ]; then echo 'Set LENZ_REPO=/path/to/Lenz' >&2; exit 1; fi && cd \"$LENZ_REPO\" && uv run python manage.py emit_openapi --output \"$OLDPWD/openapi.json\" --pretty && cd \"$OLDPWD\" && echo \"Refreshed openapi.json from $LENZ_REPO\"",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "nock": "^13.5.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
